{
  "chip": "SF32LB52",
  "memory": "nor",
  "port": "/dev/ttyUSB0",
  "baud": 1000000,
  "before": "default_reset",
  "after": "soft_reset",
  "connect_attempts": 3,
  "compat": false,
  "quiet": false,
  "read_flash": {
    "files": [
      {
        "path": "firmware_backup.bin",
        "address": "0x12020000",
        "size": "0x00100000"
      }
    ]
  }
}
